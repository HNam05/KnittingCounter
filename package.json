{
  "name": "knitting-counter-overlay",
  "version": "0.1.0",
  "description": "Windows-first Electron desktop overlay for counting knitting stitches offline.",
  "productName": "Knitting Counter Overlay",
  "main": "./out/main/main.js",
  "author": "hanne",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "dist": "npm run build && electron-builder --win zip -c.win.signAndEditExecutable=false && node scripts/write-release-checksums.mjs",
    "dist:signed": "npm run build && electron-builder --win zip && node scripts/write-release-checksums.mjs"
  },
  "build": {
    "appId": "com.hanne.knittingcounteroverlay",
    "productName": "Knitting Counter Overlay",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "distribution/START_HERE.txt",
        "to": "START_HERE.txt"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "zip"
      ],
      "artifactName": "${productName}-${version}-windows-${arch}.${ext}"
    }
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "22.15.18",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "41.2.2",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "typescript": "5.8.3",
    "vite": "7.3.2"
  }
}
